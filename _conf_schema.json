{
  "api_key": {
    "type": "string",
    "description": "MiMo API Key",
    "hint": "可在 MiMo 官方平台获取，也可以在插件 Pages 页面填写。",
    "default": ""
  },
  "base_url": {
    "type": "string",
    "description": "MiMo API Base URL",
    "default": "https://api.xiaomimimo.com/v1"
  },
  "model": {
    "type": "string",
    "description": "TTS 模型",
    "default": "mimo-v2.5-tts-voiceclone"
  },
  "output_format": {
    "type": "string",
    "description": "输出格式",
    "options": ["wav"],
    "default": "wav"
  },
  "default_context": {
    "type": "string",
    "description": "默认风格指令",
    "hint": "会作为 user 消息传给 MiMo，用于控制语气和风格；待朗读文本仍放在 assistant 消息。",
    "default": ""
  },
  "emotion_routing_enabled": {
    "type": "bool",
    "description": "启用自动情绪路由",
    "default": true
  },
  "emotion_contexts": {
    "type": "object",
    "description": "情绪风格指令映射",
    "hint": "例如 {\"happy\":\"明亮轻快\", \"sad\":\"低沉克制\"}",
    "default": {}
  },
  "segment_enabled": {
    "type": "bool",
    "description": "启用长文本分段合成",
    "default": true
  },
  "segment_threshold_chars": {
    "type": "int",
    "description": "分段阈值字符数",
    "default": 180
  },
  "segment_max_segments": {
    "type": "int",
    "description": "最大分段数",
    "default": 6
  },
  "max_text_chars": {
    "type": "int",
    "description": "单次 MiMo 请求最大文本长度",
    "default": 500
  },
  "max_voice_file_mb": {
    "type": "int",
    "description": "参考音频最大大小 MB",
    "default": 10
  },
  "max_concurrency": {
    "type": "int",
    "description": "最大并发生成数",
    "default": 1
  },
  "admin_users": {
    "type": "list",
    "description": "插件管理员用户 ID",
    "default": []
  }
}
