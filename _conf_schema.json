{
  "api_key": {
    "type": "string",
    "description": "MiMo API Key",
    "hint": "可在 MiMo 官方平台获取，也可以在插件 Pages 页面填写。",
    "default": ""
  },
  "base_url": {
    "type": "string",
    "description": "MiMo API Base URL",
    "default": "https://api.xiaomimimo.com/v1"
  },
  "model": {
    "type": "string",
    "description": "TTS 模型",
    "default": "mimo-v2.5-tts-voiceclone"
  },
  "output_format": {
    "type": "string",
    "description": "输出格式",
    "options": ["wav"],
    "default": "wav"
  },
  "default_context": {
    "type": "string",
    "description": "默认风格指令",
    "hint": "会作为 user 消息传给 MiMo，用于控制语气和风格；待朗读文本仍放在 assistant 消息。",
    "default": ""
  },
  "emotion_routing_enabled": {
    "type": "bool",
    "description": "启用自动情绪路由",
    "default": true
  },
  "emotion_contexts": {
    "type": "object",
    "description": "情绪风格指令映射",
    "hint": "例如 {\"happy\":\"明亮轻快\", \"sad\":\"低沉克制\"}",
    "items": {
      "happy": {
        "type": "string",
        "description": "happy 情绪风格指令",
        "default": ""
      },
      "sad": {
        "type": "string",
        "description": "sad 情绪风格指令",
        "default": ""
      },
      "angry": {
        "type": "string",
        "description": "angry 情绪风格指令",
        "default": ""
      },
      "neutral": {
        "type": "string",
        "description": "neutral 情绪风格指令",
        "default": ""
      }
    },
    "default": {}
  },
  "segment_enabled": {
    "type": "bool",
    "description": "启用长文本分段合成",
    "default": true
  },
  "segment_threshold_chars": {
    "type": "int",
    "description": "分段阈值字符数",
    "default": 180
  },
  "segment_max_segments": {
    "type": "int",
    "description": "最大分段数",
    "default": 6
  },
  "max_text_chars": {
    "type": "int",
    "description": "单次 MiMo 请求最大文本长度",
    "default": 500
  },
  "max_voice_file_mb": {
    "type": "int",
    "description": "参考音频最大大小 MB",
    "default": 10
  },
  "max_concurrency": {
    "type": "int",
    "description": "最大并发生成数",
    "default": 1
  },
  "reply_mode": {
    "type": "string",
    "description": "回复模式",
    "options": ["audio_only", "text_and_audio", "text_only"],
    "default": "audio_only"
  },
  "auto_tts_enabled": {
    "type": "bool",
    "description": "启用普通 LLM 回复自动语音化",
    "default": false
  },
  "auto_tts_probability": {
    "type": "string",
    "description": "普通 LLM 回复自动语音化概率，范围 0-1，例如 0.3",
    "default": "0.0"
  },
  "file_fallback_enabled": {
    "type": "bool",
    "description": "语音消息发送失败或当前版本缺少语音组件时，允许回退为文件发送",
    "default": true
  },
  "output_retention_days": {
    "type": "int",
    "description": "生成音频文件保留天数，0 表示不按时间清理",
    "default": 7
  },
  "output_max_files": {
    "type": "int",
    "description": "生成音频文件最多保留数量，0 表示不按数量清理",
    "default": 100
  },
  "admin_users": {
    "type": "list",
    "description": "插件管理员用户 ID",
    "items": {
      "type": "string"
    },
    "default": []
  }
}
